{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and progress data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "level": { "type": "string", "enum": ["A1", "A2", "B1", "B2", "C1", "C2"] },
        "xp": { "type": "integer" },
        "streak": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "level"]
    },
    "Progress": {
      "title": "Progress",
      "description": "Tracks progress for specific modules",
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "subCategory": { "type": "string" },
        "score": { "type": "integer" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["category", "score"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public and private user profile data"
    },
    "/users/{userId}/progress/{progressId}": {
      "schema": "Progress",
      "description": "User specific progress metrics"
    }
  }
}
